{"ast":null,"code":"import \"core-js/modules/es.array.push.js\";\nimport \"core-js/modules/es.iterator.constructor.js\";\nimport \"core-js/modules/es.iterator.map.js\";\nimport \"core-js/modules/es.iterator.reduce.js\";\nimport \"core-js/modules/es.set.difference.v2.js\";\nimport \"core-js/modules/es.set.intersection.v2.js\";\nimport \"core-js/modules/es.set.is-disjoint-from.v2.js\";\nimport \"core-js/modules/es.set.is-subset-of.v2.js\";\nimport \"core-js/modules/es.set.is-superset-of.v2.js\";\nimport \"core-js/modules/es.set.symmetric-difference.v2.js\";\nimport \"core-js/modules/es.set.union.v2.js\";\nimport { mapGetters } from 'vuex';\nimport AddRestaurantForm from '../components/admin/AddRestaurantForm.vue';\nimport AddMenuItemForm from '../components/admin/AddMenuItemForm.vue';\nexport default {\n  name: 'AdminView',\n  components: {\n    AddRestaurantForm,\n    AddMenuItemForm\n  },\n  data() {\n    return {\n      activeTab: 0,\n      tableSearch: '',\n      tableHeaders: [{\n        text: 'Image',\n        value: 'image',\n        sortable: false,\n        width: 60\n      }, {\n        text: 'Name',\n        value: 'name'\n      }, {\n        text: 'Cuisine',\n        value: 'cuisine_type'\n      }, {\n        text: 'Location',\n        value: 'location'\n      }, {\n        text: 'Rating',\n        value: 'average_rating'\n      }, {\n        text: 'Price',\n        value: 'price_range'\n      }, {\n        text: 'Reviews',\n        value: 'total_reviews'\n      }, {\n        text: 'Actions',\n        value: 'actions',\n        sortable: false\n      }]\n    };\n  },\n  computed: {\n    ...mapGetters(['restaurants', 'loading']),\n    adminStats() {\n      const totalReviews = this.restaurants.reduce((s, r) => s + r.total_reviews, 0);\n      const avgRating = this.restaurants.length ? (this.restaurants.reduce((s, r) => s + r.average_rating, 0) / this.restaurants.length).toFixed(1) : '0.0';\n      return [{\n        label: 'Restaurants',\n        value: this.restaurants.length,\n        icon: 'mdi-store',\n        color: 'primary'\n      }, {\n        label: 'Total Reviews',\n        value: totalReviews,\n        icon: 'mdi-comment',\n        color: 'secondary'\n      }, {\n        label: 'Avg Rating',\n        value: avgRating,\n        icon: 'mdi-star',\n        color: 'warning'\n      }, {\n        label: 'Cuisines',\n        value: [...new Set(this.restaurants.map(r => r.cuisine_type))].length,\n        icon: 'mdi-food',\n        color: 'success'\n      }];\n    }\n  },\n  created() {\n    if (!this.restaurants.length) {\n      this.$store.dispatch('fetchRestaurants');\n    }\n  },\n  methods: {\n    onRestaurantAdded() {\n      this.activeTab = 2;\n    },\n    onMenuItemAdded() {\n      this.$store.dispatch('showSnackbar', {\n        message: 'Menu item added!',\n        color: 'success',\n        icon: 'mdi-check-circle'\n      });\n    },\n    viewRestaurant(restaurant) {\n      this.$router.push({\n        name: 'restaurant-detail',\n        params: {\n          id: restaurant._id\n        }\n      });\n    }\n  }\n};","map":{"version":3,"names":["mapGetters","AddRestaurantForm","AddMenuItemForm","name","components","data","activeTab","tableSearch","tableHeaders","text","value","sortable","width","computed","adminStats","totalReviews","restaurants","reduce","s","r","total_reviews","avgRating","length","average_rating","toFixed","label","icon","color","Set","map","cuisine_type","created","$store","dispatch","methods","onRestaurantAdded","onMenuItemAdded","message","viewRestaurant","restaurant","$router","push","params","id","_id"],"sources":["src/views/AdminView.vue"],"sourcesContent":["<template>\n  <div>\n    <!-- Header -->\n    <v-sheet color=\"primary\" tile class=\"py-8\">\n      <v-container style=\"max-width:1280px;\">\n        <div class=\"d-flex align-center\">\n          <v-icon color=\"secondary\" size=\"32\" class=\"mr-3\">mdi-shield-account</v-icon>\n          <div>\n            <h1 class=\"white--text\" style=\"font-family:'Playfair Display',serif; font-size:1.8rem; font-weight:700;\">Admin Panel</h1>\n            <p class=\"grey--text text--lighten-1 mb-0\" style=\"font-size:0.85rem;\">Manage restaurants, menus, and content</p>\n          </div>\n        </div>\n      </v-container>\n    </v-sheet>\n\n    <v-container style=\"max-width:1280px;\" class=\"py-8\">\n      <!-- Stats Row -->\n      <v-row class=\"mb-6\">\n        <v-col v-for=\"stat in adminStats\" :key=\"stat.label\" cols=\"12\" sm=\"6\" md=\"3\">\n          <v-card elevation=\"1\" rounded=\"lg\" style=\"border:1px solid #E8E3D9;\">\n            <v-card-text class=\"pa-4\">\n              <div class=\"d-flex align-center justify-space-between\">\n                <div>\n                  <div class=\"grey--text caption font-weight-bold text-uppercase\" style=\"letter-spacing:0.8px;\">{{ stat.label }}</div>\n                  <div class=\"primary--text font-weight-bold mt-1\" style=\"font-family:'Playfair Display',serif; font-size:1.8rem; line-height:1;\">{{ stat.value }}</div>\n                </div>\n                <v-avatar :color=\"stat.color\" size=\"44\">\n                  <v-icon dark>{{ stat.icon }}</v-icon>\n                </v-avatar>\n              </div>\n            </v-card-text>\n          </v-card>\n        </v-col>\n      </v-row>\n\n      <!-- Tabs -->\n      <v-tabs v-model=\"activeTab\" color=\"secondary\" background-color=\"transparent\" class=\"mb-6\">\n        <v-tab class=\"text-none font-weight-semibold\">\n          <v-icon left small>mdi-store-plus</v-icon>\n          Add Restaurant\n        </v-tab>\n        <v-tab class=\"text-none font-weight-semibold\">\n          <v-icon left small>mdi-food-fork-drink</v-icon>\n          Add Menu Item\n        </v-tab>\n        <v-tab class=\"text-none font-weight-semibold\">\n          <v-icon left small>mdi-view-list</v-icon>\n          All Restaurants\n        </v-tab>\n      </v-tabs>\n\n      <v-tabs-items v-model=\"activeTab\">\n        <!-- Add Restaurant Tab -->\n        <v-tab-item>\n          <AddRestaurantForm @added=\"onRestaurantAdded\" />\n        </v-tab-item>\n\n        <!-- Add Menu Item Tab -->\n        <v-tab-item>\n          <AddMenuItemForm @added=\"onMenuItemAdded\" />\n        </v-tab-item>\n\n        <!-- All Restaurants Tab -->\n        <v-tab-item>\n          <v-card elevation=\"1\" rounded=\"lg\" style=\"border:1px solid #E8E3D9;\">\n            <v-card-title class=\"pt-4\">\n              <span class=\"section-title primary--text\">All Restaurants</span>\n              <v-spacer />\n              <v-text-field\n                v-model=\"tableSearch\"\n                append-icon=\"mdi-magnify\"\n                label=\"Search\"\n                single-line\n                hide-details\n                dense\n                outlined\n                style=\"max-width:260px;\"\n              />\n            </v-card-title>\n\n            <v-data-table\n              :headers=\"tableHeaders\"\n              :items=\"restaurants\"\n              :search=\"tableSearch\"\n              :loading=\"loading\"\n              :items-per-page=\"10\"\n              color=\"primary\"\n              class=\"pa-2\"\n            >\n              <template v-slot:item.image=\"{ item }\">\n                <v-avatar size=\"40\" rounded class=\"my-2\">\n                  <v-img :src=\"item.image\" />\n                </v-avatar>\n              </template>\n\n              <template v-slot:item.average_rating=\"{ item }\">\n                <div class=\"d-flex align-center\">\n                  <v-icon color=\"secondary\" size=\"14\" class=\"mr-1\">mdi-star</v-icon>\n                  <span class=\"font-weight-bold\" style=\"font-size:0.88rem;\">{{ item.average_rating.toFixed(1) }}</span>\n                </div>\n              </template>\n\n              <template v-slot:item.price_range=\"{ item }\">\n                <v-chip x-small color=\"secondary\" dark class=\"font-weight-bold\">{{ item.price_range }}</v-chip>\n              </template>\n\n              <template v-slot:item.actions=\"{ item }\">\n                <v-btn icon small color=\"primary\" @click=\"viewRestaurant(item)\">\n                  <v-icon small>mdi-eye</v-icon>\n                </v-btn>\n              </template>\n            </v-data-table>\n          </v-card>\n        </v-tab-item>\n      </v-tabs-items>\n    </v-container>\n  </div>\n</template>\n\n<script>\nimport { mapGetters } from 'vuex'\nimport AddRestaurantForm from '../components/admin/AddRestaurantForm.vue'\nimport AddMenuItemForm from '../components/admin/AddMenuItemForm.vue'\n\nexport default {\n  name: 'AdminView',\n  components: { AddRestaurantForm, AddMenuItemForm },\n\n  data() {\n    return {\n      activeTab: 0,\n      tableSearch: '',\n      tableHeaders: [\n        { text: 'Image', value: 'image', sortable: false, width: 60 },\n        { text: 'Name', value: 'name' },\n        { text: 'Cuisine', value: 'cuisine_type' },\n        { text: 'Location', value: 'location' },\n        { text: 'Rating', value: 'average_rating' },\n        { text: 'Price', value: 'price_range' },\n        { text: 'Reviews', value: 'total_reviews' },\n        { text: 'Actions', value: 'actions', sortable: false }\n      ]\n    }\n  },\n\n  computed: {\n    ...mapGetters(['restaurants', 'loading']),\n    adminStats() {\n      const totalReviews = this.restaurants.reduce((s, r) => s + r.total_reviews, 0)\n      const avgRating = this.restaurants.length\n        ? (this.restaurants.reduce((s, r) => s + r.average_rating, 0) / this.restaurants.length).toFixed(1)\n        : '0.0'\n      return [\n        { label: 'Restaurants', value: this.restaurants.length, icon: 'mdi-store', color: 'primary' },\n        { label: 'Total Reviews', value: totalReviews, icon: 'mdi-comment', color: 'secondary' },\n        { label: 'Avg Rating', value: avgRating, icon: 'mdi-star', color: 'warning' },\n        { label: 'Cuisines', value: [...new Set(this.restaurants.map(r => r.cuisine_type))].length, icon: 'mdi-food', color: 'success' }\n      ]\n    }\n  },\n\n  created() {\n    if (!this.restaurants.length) {\n      this.$store.dispatch('fetchRestaurants')\n    }\n  },\n\n  methods: {\n    onRestaurantAdded() {\n      this.activeTab = 2\n    },\n    onMenuItemAdded() {\n      this.$store.dispatch('showSnackbar', { message: 'Menu item added!', color: 'success', icon: 'mdi-check-circle' })\n    },\n    viewRestaurant(restaurant) {\n      this.$router.push({ name: 'restaurant-detail', params: { id: restaurant._id } })\n    }\n  }\n}\n</script>\n"],"mappings":";;;;;;;;;;;AAwHA,SAAAA,UAAA;AACA,OAAAC,iBAAA;AACA,OAAAC,eAAA;AAEA;EACAC,IAAA;EACAC,UAAA;IAAAH,iBAAA;IAAAC;EAAA;EAEAG,KAAA;IACA;MACAC,SAAA;MACAC,WAAA;MACAC,YAAA,GACA;QAAAC,IAAA;QAAAC,KAAA;QAAAC,QAAA;QAAAC,KAAA;MAAA,GACA;QAAAH,IAAA;QAAAC,KAAA;MAAA,GACA;QAAAD,IAAA;QAAAC,KAAA;MAAA,GACA;QAAAD,IAAA;QAAAC,KAAA;MAAA,GACA;QAAAD,IAAA;QAAAC,KAAA;MAAA,GACA;QAAAD,IAAA;QAAAC,KAAA;MAAA,GACA;QAAAD,IAAA;QAAAC,KAAA;MAAA,GACA;QAAAD,IAAA;QAAAC,KAAA;QAAAC,QAAA;MAAA;IAEA;EACA;EAEAE,QAAA;IACA,GAAAb,UAAA;IACAc,WAAA;MACA,MAAAC,YAAA,QAAAC,WAAA,CAAAC,MAAA,EAAAC,CAAA,EAAAC,CAAA,KAAAD,CAAA,GAAAC,CAAA,CAAAC,aAAA;MACA,MAAAC,SAAA,QAAAL,WAAA,CAAAM,MAAA,GACA,MAAAN,WAAA,CAAAC,MAAA,EAAAC,CAAA,EAAAC,CAAA,KAAAD,CAAA,GAAAC,CAAA,CAAAI,cAAA,YAAAP,WAAA,CAAAM,MAAA,EAAAE,OAAA,MACA;MACA,QACA;QAAAC,KAAA;QAAAf,KAAA,OAAAM,WAAA,CAAAM,MAAA;QAAAI,IAAA;QAAAC,KAAA;MAAA,GACA;QAAAF,KAAA;QAAAf,KAAA,EAAAK,YAAA;QAAAW,IAAA;QAAAC,KAAA;MAAA,GACA;QAAAF,KAAA;QAAAf,KAAA,EAAAW,SAAA;QAAAK,IAAA;QAAAC,KAAA;MAAA,GACA;QAAAF,KAAA;QAAAf,KAAA,UAAAkB,GAAA,MAAAZ,WAAA,CAAAa,GAAA,CAAAV,CAAA,IAAAA,CAAA,CAAAW,YAAA,IAAAR,MAAA;QAAAI,IAAA;QAAAC,KAAA;MAAA,EACA;IACA;EACA;EAEAI,QAAA;IACA,UAAAf,WAAA,CAAAM,MAAA;MACA,KAAAU,MAAA,CAAAC,QAAA;IACA;EACA;EAEAC,OAAA;IACAC,kBAAA;MACA,KAAA7B,SAAA;IACA;IACA8B,gBAAA;MACA,KAAAJ,MAAA,CAAAC,QAAA;QAAAI,OAAA;QAAAV,KAAA;QAAAD,IAAA;MAAA;IACA;IACAY,eAAAC,UAAA;MACA,KAAAC,OAAA,CAAAC,IAAA;QAAAtC,IAAA;QAAAuC,MAAA;UA
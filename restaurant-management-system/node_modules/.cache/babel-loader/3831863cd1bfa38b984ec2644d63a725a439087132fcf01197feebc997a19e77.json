{"ast":null,"code":"import { mapGetters } from 'vuex';\nexport default {\n  name: 'AddMenuItemForm',\n  data() {\n    return {\n      valid: false,\n      submitting: false,\n      form: {\n        restaurant_id: '',\n        item_name: '',\n        description: '',\n        price: '',\n        category: '',\n        preparation_time: 15,\n        is_available: true,\n        is_vegetarian: false,\n        is_vegan: false,\n        is_gluten_free: false\n      },\n      categories: ['Appetizer', 'Main Course', 'Dessert', 'Beverage', 'Salad', 'Soup', 'Sides', 'Special']\n    };\n  },\n  computed: {\n    ...mapGetters(['restaurants'])\n  },\n  methods: {\n    async submit() {\n      this.$refs.form.validate();\n      if (!this.valid) return;\n      this.submitting = true;\n      try {\n        const ok = await this.$store.dispatch('addMenuItem', this.form);\n        if (ok) {\n          this.reset();\n          this.$emit('added');\n        }\n      } finally {\n        this.submitting = false;\n      }\n    },\n    reset() {\n      this.$refs.form.reset();\n      this.form = {\n        restaurant_id: '',\n        item_name: '',\n        description: '',\n        price: '',\n        category: '',\n        preparation_time: 15,\n        is_available: true,\n        is_vegetarian: false,\n        is_vegan: false,\n        is_gluten_free: false\n      };\n    }\n  }\n};","map":{"version":3,"names":["mapGetters","name","data","valid","submitting","form","restaurant_id","item_name","description","price","category","preparation_time","is_available","is_vegetarian","is_vegan","is_gluten_free","categories","computed","methods","submit","$refs","validate","ok","$store","dispatch","reset","$emit"],"sources":["src/components/admin/AddMenuItemForm.vue"],"sourcesContent":["<template>\n  <v-card elevation=\"1\" rounded=\"lg\" style=\"border:1px solid #E8E3D9;\">\n    <v-card-title class=\"pt-4\">\n      <v-icon color=\"secondary\" class=\"mr-2\">mdi-food-fork-drink</v-icon>\n      <span class=\"section-title primary--text\">Add Menu Item</span>\n    </v-card-title>\n\n    <v-card-text>\n      <v-form ref=\"form\" v-model=\"valid\" @submit.prevent=\"submit\">\n        <v-row>\n          <v-col cols=\"12\" md=\"6\">\n            <v-autocomplete\n              v-model=\"form.restaurant_id\"\n              :items=\"restaurants\"\n              item-text=\"name\"\n              item-value=\"_id\"\n              label=\"Select Restaurant *\"\n              outlined dense color=\"primary\"\n              prepend-inner-icon=\"mdi-store\"\n              :rules=\"[v => !!v || 'Required']\"\n            />\n          </v-col>\n          <v-col cols=\"12\" md=\"6\">\n            <v-text-field v-model=\"form.item_name\" label=\"Item Name *\" outlined dense color=\"primary\"\n              :rules=\"[v => !!v || 'Required']\" />\n          </v-col>\n          <v-col cols=\"12\">\n            <v-text-field v-model=\"form.description\" label=\"Description\" outlined dense color=\"primary\" />\n          </v-col>\n          <v-col cols=\"12\" md=\"4\">\n            <v-text-field v-model.number=\"form.price\" label=\"Price ($) *\" outlined dense color=\"primary\"\n              type=\"number\" min=\"0\" step=\"0.01\" prepend-inner-icon=\"mdi-currency-usd\"\n              :rules=\"[v => (v !== '' && v >= 0) || 'Required']\" />\n          </v-col>\n          <v-col cols=\"12\" md=\"4\">\n            <v-select v-model=\"form.category\" :items=\"categories\" label=\"Category *\" outlined dense color=\"primary\"\n              :rules=\"[v => !!v || 'Required']\" />\n          </v-col>\n          <v-col cols=\"12\" md=\"4\">\n            <v-text-field v-model.number=\"form.preparation_time\" label=\"Prep Time (min)\" outlined dense\n              color=\"primary\" type=\"number\" min=\"1\" prepend-inner-icon=\"mdi-timer\" />\n          </v-col>\n          <v-col cols=\"12\">\n            <div class=\"d-flex flex-wrap\" style=\"gap:16px;\">\n              <v-switch v-model=\"form.is_available\" label=\"Available\" color=\"success\" dense inset />\n              <v-switch v-model=\"form.is_vegetarian\" label=\"Vegetarian\" color=\"green\" dense inset />\n              <v-switch v-model=\"form.is_vegan\" label=\"Vegan\" color=\"green darken-2\" dense inset />\n              <v-switch v-model=\"form.is_gluten_free\" label=\"Gluten-Free\" color=\"orange darken-1\" dense inset />\n            </div>\n          </v-col>\n        </v-row>\n\n        <div class=\"mt-2 d-flex\">\n          <v-btn color=\"secondary\" depressed large class=\"text-none font-weight-bold primary--text mr-3\"\n            style=\"border-radius:10px;\" :loading=\"submitting\" :disabled=\"!valid\" @click=\"submit\">\n            <v-icon left>mdi-plus</v-icon>\n            Add Item\n          </v-btn>\n          <v-btn text color=\"grey\" class=\"text-none\" @click=\"reset\">Reset</v-btn>\n        </div>\n      </v-form>\n    </v-card-text>\n  </v-card>\n</template>\n\n<script>\nimport { mapGetters } from 'vuex'\nexport default {\n  name: 'AddMenuItemForm',\n  data() {\n    return {\n      valid: false,\n      submitting: false,\n      form: {\n        restaurant_id: '', item_name: '', description: '',\n        price: '', category: '', preparation_time: 15,\n        is_available: true, is_vegetarian: false, is_vegan: false, is_gluten_free: false\n      },\n      categories: ['Appetizer', 'Main Course', 'Dessert', 'Beverage', 'Salad', 'Soup', 'Sides', 'Special']\n    }\n  },\n  computed: {\n    ...mapGetters(['restaurants'])\n  },\n  methods: {\n    async submit() {\n      this.$refs.form.validate()\n      if (!this.valid) return\n      this.submitting = true\n      try {\n        const ok = await this.$store.dispatch('addMenuItem', this.form)\n        if (ok) { this.reset(); this.$emit('added') }\n      } finally {\n        this.submitting = false\n      }\n    },\n    reset() {\n      this.$refs.form.reset()\n      this.form = { restaurant_id: '', item_name: '', description: '', price: '', category: '', preparation_time: 15, is_available: true, is_vegetarian: false, is_vegan: false, is_gluten_free: false }\n    }\n  }\n}\n</script>\n"],"mappings":"AAkEA,SAAAA,UAAA;AACA;EACAC,IAAA;EACAC,KAAA;IACA;MACAC,KAAA;MACAC,UAAA;MACAC,IAAA;QACAC,aAAA;QAAAC,SAAA;QAAAC,WAAA;QACAC,KAAA;QAAAC,QAAA;QAAAC,gBAAA;QACAC,YAAA;QAAAC,aAAA;QAAAC,QAAA;QAAAC,cAAA;MACA;MACAC,UAAA;IACA;EACA;EACAC,QAAA;IACA,GAAAjB,UAAA;EACA;EACAkB,OAAA;IACA,MAAAC,OAAA;MACA,KAAAC,KAAA,CAAAf,IAAA,CAAAgB,QAAA;MACA,UAAAlB,KAAA;MACA,KAAAC,UAAA;MACA;QACA,MAAAkB,EAAA,cAAAC,MAAA,CAAAC,QAAA,qBAAAnB,IAAA;QACA,IAAAiB,EAAA;UAAA,KAAAG,KAAA;UAAA,KAAAC,KAAA;QAAA;MACA;QACA,KAAAtB,UAAA;MACA;IACA;IACAqB,MAAA;MACA,KAAAL,KAAA,CAAAf,IAAA,CAAAoB,KAAA;MACA,KAAApB,IAAA;QAAAC,aAAA;QAAAC,SAAA;QAAAC,WAAA;QAAAC,KAAA;QAAAC,QAAA;QAAAC,gBAAA;QAAAC,YAAA;QAAAC,aAAA;QAAAC,QAAA;QAAAC,cAAA;MAAA;IACA;EACA;AACA","ignoreList":[]},"metadata":{},"sourceType":"module","externalDependencies":[]}
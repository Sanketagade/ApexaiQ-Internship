{"ast":null,"code":"import { mapGetters } from 'vuex';\nexport default {\n  name: 'GlobalSnackbar',\n  computed: {\n    ...mapGetters(['snackbar'])\n  },\n  methods: {\n    close() {\n      this.$store.commit('SET_SNACKBAR', {\n        ...this.snackbar,\n        show: false\n      });\n    }\n  }\n};","map":{"version":3,"names":["mapGetters","name","computed","methods","close","$store","commit","snackbar","show"],"sources":["src/components/shared/GlobalSnackbar.vue"],"sourcesContent":["<template>\n  <v-snackbar\n    v-model=\"snackbar.show\"\n    :color=\"snackbar.color\"\n    timeout=\"3500\"\n    bottom\n    right\n    elevation=\"4\"\n  >\n    <div class=\"d-flex align-center\">\n      <v-icon left small>{{ snackbar.icon }}</v-icon>\n      {{ snackbar.message }}\n    </div>\n    <template v-slot:action=\"{ attrs }\">\n      <v-btn text v-bind=\"attrs\" small @click=\"close\">Dismiss</v-btn>\n    </template>\n  </v-snackbar>\n</template>\n\n<script>\nimport { mapGetters } from 'vuex'\nexport default {\n  name: 'GlobalSnackbar',\n  computed: {\n    ...mapGetters(['snackbar'])\n  },\n  methods: {\n    close() {\n      this.$store.commit('SET_SNACKBAR', { ...this.snackbar, show: false })\n    }\n  }\n}\n</script>\n"],"mappings":"AAoBA,SAAAA,UAAA;AACA;EACAC,IAAA;EACAC,QAAA;IACA,GAAAF,UAAA;EACA;EACAG,OAAA;IACAC,MAAA;MACA,KAAAC,MAAA,CAAAC,MAAA;QAAA,QAAAC,QAAA;QAAAC,IAAA;MAAA;IACA;EACA;AACA","ignoreList":[]},"metadata":{},"sourceType":"module","externalDependencies":[]}
{"ast":null,"code":"import \"core-js/modules/es.array.push.js\";\nimport \"core-js/modules/es.iterator.constructor.js\";\nimport \"core-js/modules/es.iterator.filter.js\";\nimport { mapGetters } from 'vuex';\nimport RestaurantCard from '../components/restaurant/RestaurantCard.vue';\nimport RestaurantFilters from '../components/restaurant/RestaurantFilters.vue';\nexport default {\n  name: 'HomeView',\n  components: {\n    RestaurantCard,\n    RestaurantFilters\n  },\n  data() {\n    return {\n      searchQuery: '',\n      ratingFilter: 0,\n      cuisineFilter: 'All',\n      viewMode: 'grid',\n      searchTimeout: null\n    };\n  },\n  computed: {\n    ...mapGetters(['restaurants', 'loading', 'usingMockData']),\n    filteredRestaurants() {\n      let list = [...this.restaurants];\n      const q = (this.searchQuery || '').toLowerCase().trim();\n      if (q) {\n        list = list.filter(r => r.name.toLowerCase().includes(q) || r.location.toLowerCase().includes(q) || r.cuisine_type.toLowerCase().includes(q));\n      }\n      if (this.ratingFilter > 0) {\n        list = list.filter(r => r.average_rating >= this.ratingFilter);\n      }\n      if (this.cuisineFilter && this.cuisineFilter !== 'All') {\n        list = list.filter(r => r.cuisine_type === this.cuisineFilter);\n      }\n      return list;\n    },\n    stats() {\n      return [{\n        icon: 'mdi-store',\n        value: this.restaurants.length + '+',\n        label: 'Restaurants'\n      }, {\n        icon: 'mdi-food',\n        value: '200+',\n        label: 'Dishes'\n      }, {\n        icon: 'mdi-star',\n        value: '4.6',\n        label: 'Avg Rating'\n      }];\n    }\n  },\n  created() {\n    if (!this.restaurants.length) {\n      this.$store.dispatch('fetchRestaurants');\n    }\n  },\n  methods: {\n    onSearch() {\n      clearTimeout(this.searchTimeout);\n      this.searchTimeout = setTimeout(() => {}, 300);\n    },\n    clearSearch() {\n      this.searchQuery = '';\n    },\n    clearFilters() {\n      this.searchQuery = '';\n      this.ratingFilter = 0;\n      this.cuisineFilter = 'All';\n    },\n    goToRestaurant(restaurant) {\n      this.$router.push({\n        name: 'restaurant-detail',\n        params: {\n          id: restaurant._id\n        }\n      });\n    }\n  }\n};","map":{"version":3,"names":["mapGetters","RestaurantCard","RestaurantFilters","name","components","data","searchQuery","ratingFilter","cuisineFilter","viewMode","searchTimeout","computed","filteredRestaurants","list","restaurants","q","toLowerCase","trim","filter","r","includes","location","cuisine_type","average_rating","stats","icon","value","length","label","created","$store","dispatch","methods","onSearch","clearTimeout","setTimeout","clearSearch","clearFilters","goToRestaurant","restaurant","$router","push","params","id","_id"],"sources":["src/views/HomeView.vue"],"sourcesContent":["<template>\n  <div>\n    <!-- Hero Section -->\n    <v-sheet color=\"primary\" class=\"hero-section\" tile>\n      <v-container style=\"max-width:1280px;\">\n        <v-row align=\"center\">\n          <v-col cols=\"12\" md=\"7\">\n            <h1 class=\"hero-title white--text mb-3\">\n              Find your next<br>\n              <span class=\"secondary--text\">great meal</span>\n            </h1>\n            <p class=\"hero-subtitle mb-6\">\n              Discover top-rated restaurants, explore menus, and read genuine reviews.\n            </p>\n\n            <!-- Search -->\n            <v-text-field\n              v-model=\"searchQuery\"\n              placeholder=\"Search restaurants, cuisine or location...\"\n              solo\n              flat\n              dense\n              hide-details\n              clearable\n              prepend-inner-icon=\"mdi-magnify\"\n              class=\"search-field\"\n              style=\"border-radius:12px; max-width:560px;\"\n              @input=\"onSearch\"\n              @click:clear=\"clearSearch\"\n            />\n          </v-col>\n\n          <v-col cols=\"12\" md=\"5\" class=\"d-none d-md-flex justify-end\">\n            <div class=\"d-flex flex-wrap\" style=\"gap:12px; max-width:320px; justify-content:flex-end;\">\n              <v-chip v-for=\"stat in stats\" :key=\"stat.label\" color=\"rgba(255,255,255,0.12)\" dark class=\"pa-4\">\n                <v-icon left color=\"secondary\">{{ stat.icon }}</v-icon>\n                <div>\n                  <div class=\"font-weight-bold white--text\" style=\"font-size:1.1rem; line-height:1;\">{{ stat.value }}</div>\n                  <div class=\"grey--text text--lighten-2\" style=\"font-size:0.72rem;\">{{ stat.label }}</div>\n                </div>\n              </v-chip>\n            </div>\n          </v-col>\n        </v-row>\n      </v-container>\n    </v-sheet>\n\n    <!-- Filters -->\n    <RestaurantFilters\n      :rating-filter.sync=\"ratingFilter\"\n      :cuisine-filter.sync=\"cuisineFilter\"\n      @clear=\"clearFilters\"\n    />\n\n    <!-- Demo mode banner -->\n    <v-alert\n      v-if=\"usingMockData\"\n      color=\"info\"\n      dense\n      tile\n      text\n      icon=\"mdi-information\"\n      class=\"mb-0\"\n      style=\"border-radius:0;\"\n    >\n      <span style=\"font-size:0.85rem;\">\n        <strong>Demo Mode:</strong> Showing sample data. Start the backend server and connect MongoDB to use live data.\n      </span>\n    </v-alert>\n\n    <!-- Restaurant List -->\n    <v-container style=\"max-width:1280px;\" class=\"py-8\">\n      <!-- Header -->\n      <v-row align=\"center\" class=\"mb-5\">\n        <v-col>\n          <h2 class=\"section-title primary--text\" style=\"font-size:1.5rem;\">\n            Restaurants\n            <span v-if=\"!loading\" class=\"grey--text font-weight-regular\" style=\"font-size:0.9rem; font-family:'DM Sans',sans-serif;\">\n              — {{ filteredRestaurants.length }} found\n            </span>\n          </h2>\n        </v-col>\n        <v-col cols=\"auto\">\n          <v-btn-toggle v-model=\"viewMode\" mandatory dense color=\"primary\">\n            <v-btn small icon value=\"grid\"><v-icon small>mdi-view-grid</v-icon></v-btn>\n            <v-btn small icon value=\"list\"><v-icon small>mdi-view-list</v-icon></v-btn>\n          </v-btn-toggle>\n        </v-col>\n      </v-row>\n\n      <!-- Loading -->\n      <div v-if=\"loading\" class=\"text-center py-16\">\n        <v-progress-circular indeterminate color=\"secondary\" size=\"52\" width=\"3\" />\n        <p class=\"grey--text mt-4\">Loading restaurants...</p>\n      </div>\n\n      <!-- Empty -->\n      <div v-else-if=\"filteredRestaurants.length === 0\" class=\"text-center py-16\">\n        <v-icon size=\"72\" color=\"grey lighten-2\">mdi-silverware-fork-knife</v-icon>\n        <h3 class=\"section-title grey--text mt-4 mb-2\">No restaurants found</h3>\n        <p class=\"grey--text text--lighten-1\">Try adjusting your search or filters</p>\n        <v-btn color=\"secondary\" class=\"text-none mt-3 font-weight-bold primary--text\" depressed @click=\"clearFilters\">\n          Clear Filters\n        </v-btn>\n      </div>\n\n      <!-- Grid View -->\n      <v-row v-else-if=\"viewMode === 'grid'\">\n        <v-col\n          v-for=\"restaurant in filteredRestaurants\"\n          :key=\"restaurant._id\"\n          cols=\"12\" sm=\"6\" lg=\"4\"\n        >\n          <RestaurantCard :restaurant=\"restaurant\" @click=\"goToRestaurant\" />\n        </v-col>\n      </v-row>\n\n      <!-- List View -->\n      <div v-else>\n        <v-card\n          v-for=\"restaurant in filteredRestaurants\"\n          :key=\"restaurant._id\"\n          class=\"mb-3 list-card\"\n          elevation=\"1\"\n          rounded=\"lg\"\n          style=\"border:1px solid #E8E3D9; cursor:pointer;\"\n          @click=\"goToRestaurant(restaurant)\"\n        >\n          <v-row no-gutters>\n            <v-col cols=\"3\" md=\"2\">\n              <v-img\n                :src=\"restaurant.image\"\n                height=\"100\"\n                cover\n                style=\"border-radius:8px 0 0 8px;\"\n              />\n            </v-col>\n            <v-col class=\"pa-3\">\n              <v-row no-gutters align=\"center\">\n                <v-col>\n                  <div class=\"font-weight-bold primary--text\" style=\"font-family:'Playfair Display',serif; font-size:1.05rem;\">{{ restaurant.name }}</div>\n                  <div class=\"grey--text d-flex align-center\" style=\"font-size:0.8rem;\">\n                    <v-icon size=\"12\" class=\"mr-1\">mdi-map-marker</v-icon>{{ restaurant.location }}\n                    <v-chip x-small color=\"grey lighten-3\" class=\"ml-2\" style=\"font-size:0.7rem;\">{{ restaurant.cuisine_type }}</v-chip>\n                  </div>\n                </v-col>\n                <v-col cols=\"auto\" class=\"d-flex align-center\" style=\"gap:12px;\">\n                  <div class=\"d-flex align-center\">\n                    <v-icon color=\"secondary\" size=\"15\" class=\"mr-1\">mdi-star</v-icon>\n                    <span class=\"font-weight-bold\" style=\"font-size:0.9rem;\">{{ restaurant.average_rating.toFixed(1) }}</span>\n                    <span class=\"grey--text ml-1\" style=\"font-size:0.75rem;\">({{ restaurant.total_reviews }})</span>\n                  </div>\n                  <v-chip x-small color=\"secondary\" dark class=\"font-weight-bold\">{{ restaurant.price_range }}</v-chip>\n                  <v-icon color=\"grey\">mdi-chevron-right</v-icon>\n                </v-col>\n              </v-row>\n            </v-col>\n          </v-row>\n        </v-card>\n      </div>\n    </v-container>\n  </div>\n</template>\n\n<script>\nimport { mapGetters } from 'vuex'\nimport RestaurantCard from '../components/restaurant/RestaurantCard.vue'\nimport RestaurantFilters from '../components/restaurant/RestaurantFilters.vue'\n\nexport default {\n  name: 'HomeView',\n  components: { RestaurantCard, RestaurantFilters },\n\n  data() {\n    return {\n      searchQuery: '',\n      ratingFilter: 0,\n      cuisineFilter: 'All',\n      viewMode: 'grid',\n      searchTimeout: null\n    }\n  },\n\n  computed: {\n    ...mapGetters(['restaurants', 'loading', 'usingMockData']),\n    filteredRestaurants() {\n      let list = [...this.restaurants]\n      const q = (this.searchQuery || '').toLowerCase().trim()\n      if (q) {\n        list = list.filter(r =>\n          r.name.toLowerCase().includes(q) ||\n          r.location.toLowerCase().includes(q) ||\n          r.cuisine_type.toLowerCase().includes(q)\n        )\n      }\n      if (this.ratingFilter > 0) {\n        list = list.filter(r => r.average_rating >= this.ratingFilter)\n      }\n      if (this.cuisineFilter && this.cuisineFilter !== 'All') {\n        list = list.filter(r => r.cuisine_type === this.cuisineFilter)\n      }\n      return list\n    },\n    stats() {\n      return [\n        { icon: 'mdi-store', value: this.restaurants.length + '+', label: 'Restaurants' },\n        { icon: 'mdi-food', value: '200+', label: 'Dishes' },\n        { icon: 'mdi-star', value: '4.6', label: 'Avg Rating' }\n      ]\n    }\n  },\n\n  created() {\n    if (!this.restaurants.length) {\n      this.$store.dispatch('fetchRestaurants')\n    }\n  },\n\n  methods: {\n    onSearch() {\n      clearTimeout(this.searchTimeout)\n      this.searchTimeout = setTimeout(() => {}, 300)\n    },\n    clearSearch() { this.searchQuery = '' },\n    clearFilters() {\n      this.searchQuery = ''\n      this.ratingFilter = 0\n      this.cuisineFilter = 'All'\n    },\n    goToRestaurant(restaurant) {\n      this.$router.push({ name: 'restaurant-detail', params: { id: restaurant._id } })\n    }\n  }\n}\n</script>\n\n<style scoped>\n.hero-section {\n  padding: 64px 0 72px;\n  background: linear-gradient(135deg, #1C1C1E 0%, #2D2D30 60%, #3A2E20 100%) !important;\n}\n.hero-title {\n  font-family: 'Playfair Display', serif;\n  font-size: clamp(2rem, 5vw, 3rem);\n  font-weight: 700;\n  line-height: 1.15;\n}\n.hero-subtitle {\n  color: rgba(255,255,255,0.6);\n  font-size: 1.05rem;\n  font-weight: 300;\n}\n.search-field >>> .v-input__slot {\n  border-radius: 12px !important;\n}\n.list-card:hover {\n  box-shadow: 0 8px 24px rgba(0,0,0,0.1) !important;\n}\n</style>\n"],"mappings":";;;AAqKA,SAAAA,UAAA;AACA,OAAAC,cAAA;AACA,OAAAC,iBAAA;AAEA;EACAC,IAAA;EACAC,UAAA;IAAAH,cAAA;IAAAC;EAAA;EAEAG,KAAA;IACA;MACAC,WAAA;MACAC,YAAA;MACAC,aAAA;MACAC,QAAA;MACAC,aAAA;IACA;EACA;EAEAC,QAAA;IACA,GAAAX,UAAA;IACAY,oBAAA;MACA,IAAAC,IAAA,YAAAC,WAAA;MACA,MAAAC,CAAA,SAAAT,WAAA,QAAAU,WAAA,GAAAC,IAAA;MACA,IAAAF,CAAA;QACAF,IAAA,GAAAA,IAAA,CAAAK,MAAA,CAAAC,CAAA,IACAA,CAAA,CAAAhB,IAAA,CAAAa,WAAA,GAAAI,QAAA,CAAAL,CAAA,KACAI,CAAA,CAAAE,QAAA,CAAAL,WAAA,GAAAI,QAAA,CAAAL,CAAA,KACAI,CAAA,CAAAG,YAAA,CAAAN,WAAA,GAAAI,QAAA,CAAAL,CAAA,CACA;MACA;MACA,SAAAR,YAAA;QACAM,IAAA,GAAAA,IAAA,CAAAK,MAAA,CAAAC,CAAA,IAAAA,CAAA,CAAAI,cAAA,SAAAhB,YAAA;MACA;MACA,SAAAC,aAAA,SAAAA,aAAA;QACAK,IAAA,GAAAA,IAAA,CAAAK,MAAA,CAAAC,CAAA,IAAAA,CAAA,CAAAG,YAAA,UAAAd,aAAA;MACA;MACA,OAAAK,IAAA;IACA;IACAW,MAAA;MACA,QACA;QAAAC,IAAA;QAAAC,KAAA,OAAAZ,WAAA,CAAAa,MAAA;QAAAC,KAAA;MAAA,GACA;QAAAH,IAAA;QAAAC,KAAA;QAAAE,KAAA;MAAA,GACA;QAAAH,IAAA;QAAAC,KAAA;QAAAE,KAAA;MAAA,EACA;IACA;EACA;EAEAC,QAAA;IACA,UAAAf,WAAA,CAAAa,MAAA;MACA,KAAAG,MAAA,CAAAC,QAAA;IACA;EACA;EAEAC,OAAA;IACAC,SAAA;MACAC,YAAA,MAAAxB,aAAA;MACA,KAAAA,aAAA,GAAAyB,UAAA;IACA;IACAC,YAAA;MAAA,KAAA9B,WAAA;IAAA;IACA+B,aAAA;MACA,KAAA/B,WAAA;MACA,KAAAC,YAAA;MACA,KAAAC,aAAA;IACA;IACA8B,eAAAC,UAAA;MACA,KAAAC,OAAA,CAAAC,IAAA;QAAAtC,IAAA;QAAAuC,MAAA;UAAAC,EAAA,EAAAJ,UAAA,CAAAK;QAAA;MAAA;IACA;EACA;AACA","ignoreList":[]},"metadata":{},"sourceType":"module","externalDependencies":[]}
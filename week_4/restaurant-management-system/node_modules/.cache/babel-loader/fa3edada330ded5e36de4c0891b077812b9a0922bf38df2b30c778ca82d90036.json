{"ast":null,"code":"export default {\n  name: 'AppBar'\n};","map":{"version":3,"names":["name"],"sources":["src/components/layout/AppBar.vue"],"sourcesContent":["<template>\n  <v-app-bar app color=\"primary\" elevation=\"0\" height=\"64\">\n    <v-container class=\"d-flex align-center pa-0\" style=\"max-width:1280px\">\n      <router-link to=\"/\" class=\"text-decoration-none d-flex align-center\">\n        <v-icon color=\"secondary\" size=\"28\" class=\"mr-2\">mdi-silverware-fork-knife</v-icon>\n        <span class=\"brand-name white--text\">\n          Table<span class=\"secondary--text\">Top</span>\n        </span>\n      </router-link>\n\n      <v-spacer />\n\n      <v-btn\n        v-if=\"$route.name !== 'home'\"\n        text\n        color=\"white\"\n        class=\"text-none font-weight-medium mr-2\"\n        @click=\"$router.push('/')\"\n      >\n        <v-icon left small>mdi-arrow-left</v-icon>\n        All Restaurants\n      </v-btn>\n\n      <v-btn\n        outlined\n        color=\"secondary\"\n        class=\"text-none font-weight-semibold\"\n        small\n        @click=\"$router.push('/admin')\"\n      >\n        <v-icon left small>mdi-shield-account</v-icon>\n        Admin\n      </v-btn>\n    </v-container>\n  </v-app-bar>\n</template>\n\n<script>\nexport default {\n  name: 'AppBar'\n}\n</script>\n\n<style scoped>\n.brand-name {\n  font-family: 'Playfair Display', serif;\n  font-size: 1.6rem;\n  font-weight: 700;\n  letter-spacing: -0.5px;\n}\n</style>\n"],"mappings":"AAsCA;EACAA,IAAA;AACA","ignoreList":[]},"metadata":{},"sourceType":"module","externalDependencies":[]}